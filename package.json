{
    "name": "ruby-nights",
    "displayName": "Ruby Nights",
    "description": "A dark VS Code theme with rich ruby and garnet tones. Available in Ruby, Ruby Midnight, Garnet, and Garnet Midnight variants.",
    "version": "1.0.0",
    "icon": "icon.png",
    "publisher": "lekaledian",
    "author": {
        "name": "Ledian Leka",
        "url": "https://ledian63s.github.io/"
    },
    "homepage": "https://ledian63s.github.io/",
    "license": "Apache-2.0",
    "galleryBanner": {
        "color": "#120a11",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.70.0"
    },
    "categories": [
        "Themes"
    ],
    "contributes": {
        "themes": [
            {
                "label": "Lumos Ruby",
                "uiTheme": "vs-dark",
                "path": "./themes/lumos-color-theme.json"
            },
            {
                "label": "Lumos Ruby Midnight",
                "uiTheme": "vs-dark",
                "path": "./themes/lumos-ruby-midnight.json"
            },
            {
                "label": "Lumos Garnet",
                "uiTheme": "vs-dark",
                "path": "./themes/lumos-garnet.json"
            },
            {
                "label": "Lumos Garnet Midnight",
                "uiTheme": "vs-dark",
                "path": "./themes/lumos-garnet-midnight.json"
            }
        ]
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Ledian63S/ruby-nights"
    },
    "bugs": {
        "url": "https://github.com/Ledian63S/ruby-nights/issues"
    },
    "keywords": [
        "theme",
        "dark",
        "ruby",
        "garnet",
        "ruby-nights",
        "color-theme"
    ]
}