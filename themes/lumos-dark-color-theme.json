	"tokenColors": [
		{
			"settings": {
				"background": "#121214",
				"foreground": "#f2f3f5"
			}
		},
		{
			"name": "Comment",
			"scope": ["comment"],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#626a73"
			}
		},
		{
			"name": "String",
			"scope": ["string", "constant.other.symbol"],
			"settings": {
				"foreground": "#a4bd00"
			}
		},
		{
			"name": "Regular Expressions and Escape Characters",
			"scope": ["string.regexp", "constant.character", "constant.other"],
			"settings": {
				"foreground": "#95e6cb"
			}
		},
		{
			"name": "Number",
			"scope": ["constant.numeric"],
			"settings": {
				"foreground": "#e6e600"
			}
		},
		{
			"name": "Built-in constants",
